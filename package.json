{
	"name": "@anephenix/mcg",
	"version": "0.0.20",
	"description": "Model Component Generator for Objection.js",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"types",
		"README.md"
	],
	"bin": "./dist/bin/mcg",
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"postbuild": "echo \"#!/usr/bin/env node\nimport('./mcg.js');\" > dist/bin/mcg && chmod +x dist/bin/mcg",
		"cover": "cross-env NODE_ENV=test npx vitest --run --exclude=test/data/* --no-file-parallelism --coverage",
		"format": "npx @biomejs/biome check . --write",
		"lint": "npx @biomejs/biome check .",
		"lint:package": "npx publint",
		"prepare-patch-release": "npm run size && npm run update-changelog && git add CHANGELOG.md && git commit -m \"Updated changelog\" && npm version patch",
		"publish-patch-release": "npm run prepare-patch-release && git push origin master && git push --tags",
		"size": "size-limit",
		"test": "cross-env NODE_ENV=test npx vitest --run --exclude=test/data/* --no-file-parallelism",
		"test:build:commonjs": "node e2e/test-commonjs.cjs",
		"test:build:esm": "node e2e/test-esm.js",
		"test:e2e": "npm run build && npm run test:build:commonjs && npm run test:build:esm",
		"update-changelog": "node --experimental-strip-types scripts/update-changelog.ts",
		"prepare": "husky",
		"watch": "tsc --project tsconfig.json --watch"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/anephenix/mcg.git"
	},
	"homepage": "https://github.com/anephenix/mcg",
	"bugs": {
		"url": "https://github.com/anephenix/mcg/issues"
	},
	"keywords": [
		"objection",
		"model",
		"generator"
	],
	"husky": {
		"hooks": {
			"pre-commit": "npm run lint && npm t && npm run size"
		}
	},
	"author": "Paul Jensen <paul@anephenix.com>",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@size-limit/file": "^12.0.0",
		"@types/node": "^25.5.0",
		"@types/pluralize": "^0.0.33",
		"@vitest/coverage-v8": "^4.0.18",
		"cross-env": "^10.0.0",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"publint": "^0.3.14",
		"size-limit": "^12.0.0",
		"size-limit-node-esbuild": "^0.4.0",
		"typescript": "^6.0.2",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"commander": "^14.0.0",
		"pluralize": "^8.0.0",
		"to-case": "^2.0.0"
	},
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "10 kB"
		}
	]
}
